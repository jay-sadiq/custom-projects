# Copy to .env and adjust values

# Development (default: core.settings.dev via manage.py)
DEBUG=True
SECRET_KEY=change-me-in-production

# Production (core.settings.prod via wsgi/asgi / Docker / Fly.io)
# ALLOWED_HOSTS=your-app.fly.dev,yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://your-app.fly.dev,https://yourdomain.com
# SECURE_SSL_REDIRECT=True
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DATABASE_SSL_REQUIRE=True

# Media storage (optional — use S3-compatible bucket in production)
# USE_S3_STORAGE=True
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1

# AI rate limits (web + API)
# AI_RATE_LIMIT=10/h

# AI
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3
GEMINI_API_KEY=

# External APIs
GOOGLE_PLACES_API_KEY=
WEATHER_API_KEY=

# Logging
# LOG_LEVEL=INFO
